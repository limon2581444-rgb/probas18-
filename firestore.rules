rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3 & 4. Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // Relationship: is current user a participant in this chat?
    function isParticipant(chatId) {
      return isSignedIn() && exists(/databases/$(database)/documents/chats/$(chatId)) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return (data.displayName is string && data.displayName.size() <= 100)
        && (!('photoURL' in data) || (data.photoURL is string || data.photoURL == null))
        && (!('name' in data) || (data.name is string || data.name == null))
        && (!('photo' in data) || (data.photo is string || data.photo == null))
        && (!('statusMessage' in data) || (data.statusMessage is string || data.statusMessage == null))
        && (!('phoneNumber' in data) || (data.phoneNumber is string || data.phoneNumber == null))
        && (!('email' in data) || (data.email is string || data.email == null))
        && (!('username' in data) || (data.username is string || data.username == null))
        && (!('uid' in data) || (data.uid == request.auth.uid))
        && (!('isOnline' in data) || (data.isOnline is bool))
        && (!('lastSeen' in data) || (data.lastSeen is timestamp));
    }

    function isValidChat(data) {
      return data.participants is list && data.participants.size() >= 2 && data.participants.size() <= 100
        && data.type in ['direct', 'group']
        && request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return (data.senderId == request.auth.uid || data.sender == request.auth.uid)
        && (data.createdAt == request.time || data.time == request.time)
        && data.type in ['text', 'image', 'voice']
        && (!('text' in data) || (data.text is string && data.text.size() <= 2000))
        && (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 500))
        && (!('image' in data) || (data.image is string && data.image.size() <= 600));
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'statusMessage', 'isOnline', 'lastSeen', 'email', 'username', 'uid', 'phoneNumber', 'name', 'photo']);
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in existing().participants;
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt'])
        );
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isParticipant(chatId);
      allow create: if isParticipant(chatId) && isValidId(messageId) && isValidMessage(incoming());
      allow delete, update: if false; // Messages are immutable for now
    }

    match /system/connection_test {
      allow read: if true;
    }
  }
}
