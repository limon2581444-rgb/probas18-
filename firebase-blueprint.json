{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "photo": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "statusMessage": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two or more users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["direct", "group"] },
        "lastMessage": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "senderId": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "type"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "sender": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "voice"] },
        "mediaUrl": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "time": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Registry of users"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Active conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat"
    }
  }
}
